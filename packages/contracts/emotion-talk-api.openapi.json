  "components": {
    "schemas": {
      "AsrSessionRequest": {
        "properties": {
          "spaceId": {
            "type": "string",
            "title": "Spaceid"
          },
          "recordingId": {
            "type": "string",
            "title": "Recordingid"
          },
          "provider": {
            "type": "string",
            "title": "Provider",
            "default": "paraformer"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "default": "paraformer-realtime-8k-v2"
          }
        },
        "type": "object",
        "required": [
          "spaceId",
          "recordingId"
        ],
        "title": "AsrSessionRequest"
      },
      "AudioUploadAuthorizationRequest": {
        "properties": {
          "mimeType": {
            "type": "string",
            "title": "Mimetype",
            "default": "audio/mpeg"
          },
          "byteSize": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bytesize"
          },
          "checksumSha256": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Checksumsha256"
          }
        },
        "type": "object",
        "title": "AudioUploadAuthorizationRequest"
      },
      "ExpertAdviceJobRequest": {
        "properties": {
          "contextScope": {
            "type": "string",
            "title": "Contextscope",
            "default": "current_only"
          },
          "historyLimit": {
            "type": "integer",
            "maximum": 20.0,
            "minimum": 0.0,
            "title": "Historylimit",
            "default": 5
          },
          "historicalContext": {
            "items": {
              "$ref": "#/components/schemas/HistoricalContextRequest"
            },
            "type": "array",
            "title": "Historicalcontext"
          },
          "includeProfile": {
            "type": "boolean",
            "title": "Includeprofile",
            "default": false
          }
        },
        "type": "object",
        "title": "ExpertAdviceJobRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HistoricalContextRequest": {
        "properties": {
          "sourceType": {
            "type": "string",
            "title": "Sourcetype",
            "default": "recording"
          },
          "sourceId": {
            "type": "string",
            "title": "Sourceid"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "createdAtText": {
            "type": "string",
            "title": "Createdattext",
            "default": ""
          },
          "summary": {
            "type": "string",
            "title": "Summary"
          },
          "keyPoints": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Keypoints"
          },
          "relevance": {
            "type": "string",
            "title": "Relevance",
            "default": "selected"
          }
        },
        "type": "object",
        "required": [
          "sourceId",
          "title",
          "summary"
        ],
        "title": "HistoricalContextRequest"
      },
      "MarkdownJobRequest": {
        "properties": {
          "markdown": {
            "type": "string",
            "minLength": 1,
            "title": "Markdown"
          },
          "sourceType": {
            "type": "string",
            "title": "Sourcetype",
            "default": "recording"
          },
          "sourceId": {
            "type": "string",
            "title": "Sourceid",
            "default": "dev-recording"
          },
          "contextScope": {
            "type": "string",
            "title": "Contextscope",
            "default": "current_only"
          },
          "historicalContext": {
            "items": {
              "$ref": "#/components/schemas/HistoricalContextRequest"
            },
            "type": "array",
            "title": "Historicalcontext"
          }
        },
        "type": "object",
        "required": [
          "markdown"
        ],
        "title": "MarkdownJobRequest"
      },
      "RecordingCreateRequest": {
        "properties": {
          "spaceId": {
            "type": "string",
            "title": "Spaceid"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "startedAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Startedat"
          },
          "clientRecordingId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Clientrecordingid"
          }
        },
        "type": "object",
        "required": [
          "spaceId"
        ],
        "title": "RecordingCreateRequest"
      },
      "SpaceCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "default": "默认倾诉空间"
          }
        },
        "type": "object",
        "title": "SpaceCreateRequest"
      },
      "SummaryJobRequest": {
        "properties": {
          "force": {
            "type": "boolean",
            "title": "Force",
            "default": false
          }
        },
        "type": "object",
        "title": "SummaryJobRequest"
      },
      "TranscriptSegmentRequest": {
        "properties": {
          "speaker": {
            "type": "string",
            "title": "Speaker",
            "default": "发言人"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp",
            "default": ""
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "title": "Text"
          },
          "startMs": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Startms"
          },
          "endMs": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Endms"
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "TranscriptSegmentRequest"
      },
      "TranscriptSubmitRequest": {
        "properties": {
          "markdown": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Markdown"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "createdAtText": {
            "type": "string",
            "title": "Createdattext",
            "default": ""
          },
          "durationText": {
            "type": "string",
            "title": "Durationtext",
            "default": ""
          },
          "segments": {
            "items": {
              "$ref": "#/components/schemas/TranscriptSegmentRequest"
            },
            "type": "array",
            "title": "Segments"
          }
        },
        "type": "object",
        "title": "TranscriptSubmitRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}